# Environment Variables Template
# Copy this file to .env.local and fill in your values

# Backend Configuration
PORT=3000
NODE_ENV=development

# Database (example - update with your actual database configuration)
DATABASE_URL=postgresql://username:password@localhost:5432/sustainable_systems

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=7d

# External API Keys (add as needed)
# CARBON_API_KEY=your-carbon-api-key
# WEATHER_API_KEY=your-weather-api-key

# Email Configuration (if using email services)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-email-password

# Redis (if using caching)
# REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info