{
  "name": "@sustainable-systems/backend",
  "version": "1.0.0",
  "description": "Backend services for sustainable systems platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
